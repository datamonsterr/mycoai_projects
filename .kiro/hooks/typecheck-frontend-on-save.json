{
  "version": "v1",
  "hooks": [
    {
      "name": "Typecheck Frontend on Save",
      "trigger": "PostFileSave",
      "description": "Runs TypeScript type checking on frontend files when saved",
      "matcher": "mycoai_retrieval_frontend/.*\\.(ts|tsx)$",
      "action": {
        "type": "command",
        "command": "cd /home/dat/dev/mycoai && pnpm --dir mycoai_retrieval_frontend typecheck 2>&1 | tail -20",
        "timeout": 30
      }
    }
  ]
}