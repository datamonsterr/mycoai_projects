{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "autoupdate": true,
  "mcp": {
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "markitdown-mcp",
        "markitdown-mcp"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  },
  "agent": {
    "superagent": {
      "description": "Primary autonomous delivery agent for MycoAI product and research workflows",
      "mode": "primary",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 40
    },
    "autoresearch": {
      "description": "Autoresearch loop agent for fungal classification experiments",
      "mode": "primary",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 20
    },
    "prepare": {
      "description": "Scaffolds new experiment folders with program.md, prepare.py, run_accuracy.py",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 10
    },
    "test-writer": {
      "description": "Writes focused backend/frontend tests and small harness updates when needed",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 16
    },
    "test-runner": {
      "description": "Runs repo-specific checks, groups failures, and returns actionable summaries",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 12
    },
    "manual-browser-tester": {
      "description": "Performs manual browser or API validation and records definition-of-done evidence",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 16
    },
    "e2e-writer": {
      "description": "Authors or updates end-to-end tests for scientist-facing user journeys",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.7",
      "temperature": 0.1,
      "steps": 20
    },
    "explore": {
      "description": "Fast read-only agent for exploring codebases",
      "mode": "subagent",
      "tools": {
        "read": true,
        "grep": true,
        "glob": true,
        "list": true,
        "edit": false,
        "bash": false
      }
    }
  },
  "permission": "allow",
  "instructions": [
    ".opencode/rules/experiment-visualization.md",
    ".opencode/rules/branch-naming.md",
    ".opencode/rules/frontend-react-skills.md",
    ".opencode/rules/backend-reimplementation.md",
    ".opencode/rules/document-markdown-reading.md",
    ".opencode/rules/typescript-conventions.md",
    ".opencode/rules/testing-delivery.md"
  ],
  "watcher": {
    "ignore": [
      "**/__pycache__/**",
      "**/.git/**",
      "**/node_modules/**",
      "**/.venv/**",
      "**/.mypy_cache/**",
      "**/.pytest_cache/**",
      "**/.ruff_cache/**",
      "Dataset/**",
      "results/**",
      "weights/**",
      ".agents/**",
      ".claude/**",
      ".qdrant_storage/**",
      "**/qdrant_storage/**",
      "**/*.jpg",
      "**/*.png",
      "**/*.pt",
      "**/*.pth",
      "**/*.pkl",
      "**/*.zip",
      "**/*.mmap",
      "**/*.npy",
      "**/*.npz"
    ]
  },
  "snapshot": false
}
