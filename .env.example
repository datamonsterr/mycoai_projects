# MycoAI Retrieval — Environment Variables
# Copy to .env and fill in secrets.

# Backend
MYCOAI_BACKEND_ENVIRONMENT=production
MYCOAI_BACKEND_HOST=0.0.0.0
MYCOAI_BACKEND_PORT=8000

# Qdrant
MYCOAI_QDRANT_HOST=qdrant
MYCOAI_QDRANT_PORT=6333
MYCOAI_QDRANT_COLLECTION=mycoai

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://mycoai:devpassword@postgres:5432/mycoai

# Redis
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost

# File paths
UPLOAD_DIR=/data/uploads
WEIGHTS_DIR=/data/weights

# Docker Compose production secrets
POSTGRES_PASSWORD=replace-with-strong-password
