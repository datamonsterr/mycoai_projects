// MycoAI Retrieval Backend — Thesis-Level ERD
// PostgreSQL schema for graduation report

Table users {
  id uuid [pk]
  email varchar [unique, not null]
  password_hash varchar [not null]
  name varchar [not null]
  role varchar [not null, default: 'user', note: 'user | owner']
  is_active boolean [not null, default: true]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
}

Table refresh_tokens {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  token_hash varchar [not null]
  expires_at timestamp [not null]
  created_at timestamp [not null, default: `now()`]
}

Table invite_tokens {
  id uuid [pk]
  user_id uuid [ref: > users.id]
  email varchar [not null]
  token_hash varchar [not null]
  is_used boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
}

Table species {
  id uuid [pk]
  name varchar [unique, not null]
  description text
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  archived_at timestamp
}

Table media {
  id uuid [pk]
  name varchar [unique, not null]
  description text
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  archived_at timestamp
}

Table strains {
  id uuid [pk]
  species_id uuid [ref: > species.id, not null]
  name varchar [not null]
  source varchar
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  archived_at timestamp
}

Table images {
  id uuid [pk]
  strain_id uuid [ref: > strains.id, not null]
  species_id uuid [ref: > species.id]
  media_id uuid [ref: > media.id]
  angle varchar
  file_path varchar [not null]
  prepared_path varchar
  pipeline_path varchar
  data_update_status varchar [default: 'pending', note: 'pending | updated | archived']
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]
  archived_at timestamp
}

Table segments {
  id uuid [pk]
  image_id uuid [ref: > images.id, not null]
  segment_index integer [not null]
  crop_path varchar
  bbox_x real
  bbox_y real
  bbox_w real
  bbox_h real
  segmentation_method varchar [note: 'kmeans | yolo']
  qdrant_point_id varchar
  is_archived boolean [not null, default: false]
  created_at timestamp [not null, default: `now()`]
}

Table retrieval_jobs {
  id uuid [pk]
  user_id uuid [ref: > users.id, not null]
  job_type varchar [not null, note: 'single | batch']
  status varchar [not null, default: 'queued']
  config jsonb
  input_summary jsonb
  error_message text
  started_at timestamp
  completed_at timestamp
  created_at timestamp [not null, default: `now()`]
}

Table retrieval_results {
  id uuid [pk]
  job_id uuid [ref: > retrieval_jobs.id, not null]
  strain_name varchar
  rank integer
  species_name varchar
  score real
}

Table retrieval_neighbors {
  id uuid [pk]
  result_id uuid [ref: > retrieval_results.id, not null]
  neighbor_image_id varchar
  neighbor_strain varchar
  neighbor_species varchar
  similarity real
  media varchar
  segment_index integer
}

Table feedback {
  id uuid [pk]
  submitter_id uuid [ref: > users.id, not null]
  reviewer_id uuid [ref: > users.id]
  result_id uuid [ref: > retrieval_results.id]
  image_id uuid [ref: > images.id]
  source varchar [note: 'retrieval | dataset']
  feedback_type varchar [not null, note: 'correction | contribution | bug']
  query_strain varchar
  predicted_species varchar
  suggested_species varchar
  description text
  status varchar [not null, default: 'pending', note: 'pending | approved | rejected | needs_edit']
  review_note text
  submitted_at timestamp [not null, default: `now()`]
  reviewed_at timestamp
}

Table training_jobs {
  id uuid [pk]
  triggered_by uuid [ref: > users.id, not null]
  job_type varchar [not null]
  status varchar [not null, default: 'queued']
  progress real
  changes_since_last jsonb
  model_version varchar
  is_deployed boolean [default: false]
  started_at timestamp
  completed_at timestamp
  created_at timestamp [not null, default: `now()`]
}

Table audit_log {
  id bigserial [pk]
  user_id uuid [ref: > users.id]
  action varchar [not null]
  entity_type varchar
  entity_id varchar
  changes jsonb
  ip_address inet
  created_at timestamp [not null, default: `now()`]
}

Table system_state {
  key varchar [pk]
  value jsonb
  updated_at timestamp [not null, default: `now()`]
}

Table qdrant_index_state {
  id uuid [pk]
  segment_id uuid [ref: > segments.id]
  qdrant_point_id varchar
  collection_name varchar
  indexed_at timestamp
  last_updated timestamp
  is_active boolean [default: true]
}
