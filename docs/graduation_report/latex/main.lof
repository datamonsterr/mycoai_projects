\contentsline {figure}{\numberline {2.1}{\ignorespaces Overall fungal retrieval research pipeline from dish image to final species prediction.}}{12}{figure.caption.25}%
\contentsline {figure}{\numberline {2.2}{\ignorespaces KMeans segmentation pipeline --- step-by-step visualization (source, preprocessed dish, colony bounding boxes).}}{14}{figure.caption.29}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces KMeans (left) vs YOLO (right) bounding box comparison for strain DTO 148-D1 (obverse angle) across four growth media. KMeans boxes (blue) tend to be wider on bright colonies with agar flare, while YOLO boxes (red) track the true colony boundary more tightly.}}{14}{figure.caption.30}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces Training curves for the supervised fine-tuning stage across 5 folds.}}{16}{figure.caption.32}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces Feature extractor comparison across three families: fine-tuned deep learning (blue), pretrained deep learning (orange), and traditional hand-crafted (green). All configurations use weighted aggregation, E1 environment strategy, and $K=5$.}}{17}{figure.caption.39}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces Top retrieval configurations grouped by extractor family (freq\_strength aggregation, $K=5$). Fine-tuned CNNs dominate the top ranks, followed by pretrained CNNs and traditional descriptors.}}{18}{figure.caption.46}%
\contentsline {figure}{\numberline {2.7}{\ignorespaces Cross-validation heatmaps showing accuracy patterns across $K$ values, aggregation strategies, and environment configurations. Higher accuracy concentrates at small $K$ with freq\_strength aggregation.}}{19}{figure.caption.50}%
\contentsline {figure}{\numberline {2.8}{\ignorespaces Comparison of base and fine-tuned retrieval configurations. Fine-tuned EfficientNetB1 dominates the ranking and improves mean accuracy by nearly 29 percentage points over the best ImageNet baseline.}}{20}{figure.caption.51}%
\contentsline {figure}{\numberline {2.9}{\ignorespaces Confusion matrices for top fine-tuned and pretrained configurations. Each cell shows count and row-normalized fraction from 240 aggregated predictions (8 species $\times $ 6 test sets $\times $ 5 folds).}}{21}{figure.caption.53}%
\contentsline {figure}{\numberline {2.10}{\ignorespaces Confusion matrices for best traditional and worst fine-tuned configurations, illustrating the diagnostic gap between extractor families.}}{22}{figure.caption.54}%
\contentsline {figure}{\numberline {2.11}{\ignorespaces Distribution of the top retrieval score $s_0$ for known versus unknown incoming test sets. Known samples show a higher mean score (0.252) than unknown samples (0.178), indicating useful but overlapping threshold signal.}}{23}{figure.caption.58}%
\contentsline {figure}{\numberline {2.12}{\ignorespaces Known-species retrieval accuracy after label normalization. Species names in the incoming dataset omit the ``Penicillium'' prefix, so normalized comparison is required for reliable scoring.}}{23}{figure.caption.59}%
\contentsline {figure}{\numberline {2.13}{\ignorespaces Top threshold strategies ranked by F1 on the corrected diverse retrieval set.}}{24}{figure.caption.60}%
