\addvspace {10\p@ }
\contentsline {figure}{\numberline {1.1}{\ignorespaces Three fungal strains across five growth media (oblique view). Green border = same species as reference strain; red border = different species.}}{2}{figure.1.1}%
\contentsline {figure}{\numberline {1.2}{\ignorespaces Dataset scale overview showing the relationship between original images, segmented colonies, strains, and species.}}{3}{figure.1.2}%
\contentsline {figure}{\numberline {1.3}{\ignorespaces Number of original dish images per species in the curated dataset.}}{4}{figure.1.3}%
\contentsline {figure}{\numberline {1.4}{\ignorespaces Images per strain, colored by species. Most strains contribute 14 images (7 media $\times $ 2 angles).}}{4}{figure.1.4}%
\contentsline {figure}{\numberline {1.5}{\ignorespaces Distribution of images across seven growth media.}}{5}{figure.1.5}%
\contentsline {figure}{\numberline {1.6}{\ignorespaces Heatmap showing the number of images per species per growth medium.}}{6}{figure.1.6}%
\contentsline {figure}{\numberline {1.7}{\ignorespaces Few-shot classification challenge. Each point represents one species, positioned by its number of strains and number of images.}}{7}{figure.1.7}%
\contentsline {figure}{\numberline {1.8}{\ignorespaces Comparison between the curated dataset used for retrieval evaluation and the incoming/new\_data dataset used for threshold analysis.}}{8}{figure.1.8}%
\contentsline {figure}{\numberline {1.9}{\ignorespaces Distribution of strains per species. Most incoming/new\_data species have only one strain, while the curated/original dataset has deeper strain coverage per species.}}{8}{figure.1.9}%
\contentsline {figure}{\numberline {1.10}{\ignorespaces Top 20 species by image count in the incoming/new\_data dataset. The long tail supports open-set evaluation rather than dense supervised training.}}{9}{figure.1.10}%
\contentsline {figure}{\numberline {1.11}{\ignorespaces Media distribution in the incoming/new\_data dataset used for threshold analysis.}}{10}{figure.1.11}%
\contentsline {figure}{\numberline {1.12}{\ignorespaces Example segmented colony crops from incoming/new\_data across multiple growth media.}}{11}{figure.1.12}%
\contentsline {figure}{\numberline {1.13}{\ignorespaces Bounding-box overlays from the fine-tuned YOLO26 segmentation pipeline on \texttt {Dataset/new\_data\_prepared/} images from the incoming/new\_data collection. Used as a qualitative segmentation illustration rather than as the primary retrieval preprocessing path.}}{12}{figure.1.13}%
\contentsline {figure}{\numberline {1.14}{\ignorespaces High-level architecture of the retrieval-based classification pipeline. A query image passes through segmentation, feature extraction, vector search, and aggregation to produce a species prediction.}}{14}{figure.1.14}%
\addvspace {10\p@ }
\contentsline {figure}{\numberline {2.1}{\ignorespaces Overall fungal retrieval research pipeline: six-stage algorithm flow from dish image preprocessing through colony segmentation, feature extraction, Qdrant vector indexing, nearest-neighbor retrieval with aggregation, and threshold-based known-vs-unknown species prediction.}}{19}{figure.2.1}%
\contentsline {figure}{\numberline {2.2}{\ignorespaces KMeans segmentation pipeline --- step-by-step visualization (source, preprocessed dish, colony bounding boxes).}}{20}{figure.2.2}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces KMeans (left) vs YOLO (right) bounding box comparison for strain DTO 148-D1 (obverse angle) across four growth media. KMeans boxes (blue) tend to be wider on bright colonies with agar flare, while YOLO boxes (red) track the true colony boundary more tightly.}}{21}{figure.2.3}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces Augmentation policy preview: random crops, brightness/contrast jitter, rotation, and the combined view applied to a sample colony segment.}}{23}{figure.2.4}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces Training curves for the supervised fine-tuning stage across 5 folds.}}{24}{figure.2.5}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces YOLO-segment retrieval comparison across three extractor families: fine-tuned deep learning (blue), pretrained deep learning (orange), and traditional hand-crafted (green). Each extractor is summarized by mean accuracy (solid bar), max accuracy (dot), and min accuracy (line cap) across the evaluated retrieval settings.}}{27}{figure.2.6}%
\contentsline {figure}{\numberline {2.7}{\ignorespaces Top 15 retrieval configurations ranked by accuracy at E1 (Same Medium) with freq\_strength aggregation. The leading entries mix pretrained and fine-tuned deep backbones, while traditional descriptors remain lower-ranked.}}{29}{figure.2.7}%
\contentsline {figure}{\numberline {2.8}{\ignorespaces Feature extractors ranked by mean retrieval accuracy (YOLO, E1 same-medium, freq\_strength aggregation, all K). Fine-tuned EfficientNetB1 achieves highest mean (78.0\%), followed by MobileNetV2 FT (76.8\%) and EfficientNetB1 PT (74.4\%). Traditional descriptors (Gabor at 40.5\%, HOG at 46.4\%) occupy the bottom ranks. Max accuracy shown in parentheses.}}{29}{figure.2.8}%
\contentsline {figure}{\numberline {2.9}{\ignorespaces YOLO vs K-Means segmentation retrieval accuracy at $K=5$ with freq\_strength aggregation. YOLO segments (green) and K-Means segments (blue) compared across three configurations. The gap is most pronounced for deep learning extractors (EfficientNetB1 FT) on E1, where YOLO dominates. ColorHist HSV performs comparably across both segmentations.}}{30}{figure.2.9}%
\contentsline {figure}{\numberline {2.10}{\ignorespaces Heatmap: K $\times $ Media Strategy (mean accuracy across best fine-tuned extractors). Small K (3--5) on E1 (Same Medium) produces strongest results, while larger K values dilute the retrieval signal with noisier neighbors.}}{31}{figure.2.10}%
\contentsline {figure}{\numberline {2.11}{\ignorespaces Heatmap: K $\times $ Aggregation Strategy (mean across best FT extractors, all media). Freq$\times $Strength at low K (3--5) consistently dominates.}}{31}{figure.2.11}%
\contentsline {figure}{\numberline {2.12}{\ignorespaces Heatmap: Aggregation $\times $ Media (mean across best FT extractors, all K). Freq$\times $Strength on E1 achieves highest accuracy.}}{32}{figure.2.12}%
\contentsline {figure}{\numberline {2.13}{\ignorespaces Cross-validation accuracy heatmap: aggregation strategy vs $K$ (mean across media and extractors). \texttt {freq\_strength} at low $K$ consistently dominates.}}{33}{figure.2.13}%
\contentsline {figure}{\numberline {2.14}{\ignorespaces Fold-specific ResNet50 and EfficientNetB1 training curves. Both architectures converge within 10--15 epochs on YOLO colony segments.}}{34}{figure.2.14}%
\contentsline {figure}{\numberline {2.15}{\ignorespaces Per-fold retrieval accuracy distribution for the best cross-validation setting, using fold-specific Qdrant collections and fold-matched backbone weights.}}{35}{figure.2.15}%
\contentsline {figure}{\numberline {2.16}{\ignorespaces Threshold retrieval pipeline for open-set species detection. Diverse incoming dataset strains are segmented, embedded with EfficientNetB1, retrieved against the full reference collection, and scored with threshold formulas for known/unknown decision.}}{36}{figure.2.16}%
\contentsline {figure}{\numberline {2.17}{\ignorespaces (Left) Top-1 score distribution for known ($n=48$, $\mu =0.195$) versus unknown ($n=294$, $\mu =0.143$) test sets. Known samples are right-shifted, but the overlap is still substantial. (Right) Per-species known-class retrieval accuracy after label normalization across 5 species. \emph {P. polonicum} is strongest (12/12), while \emph {P. melanoconidium} remains the hardest case (0/6).}}{37}{figure.2.17}%
\contentsline {figure}{\numberline {2.18}{\ignorespaces Confusion matrix for retrieval predictions with an UNKNOWN class added for the incoming diverse set. The evaluation contains 48 known test sets and 294 unknown test sets. Known-species accuracy is 66.7\% (32/48) after label normalization. Major failure modes remain \emph {P. melanoconidium} $\rightarrow $ \emph {P. polonicum}/\emph {P. viridicatum} and cross-confusion involving \emph {P. neoechinulatum}. Unknown strains overwhelmingly collapse onto a few frequent reference species, especially \emph {P. polonicum} and \emph {P. tricolor}, confirming that threshold rejection is still required on top of nearest-neighbour retrieval.}}{38}{figure.2.18}%
\contentsline {figure}{\numberline {2.19}{\ignorespaces Threshold experiment F1 scores across 576 formula-algorithm combinations. Each dot is one evaluated strategy; labels mark the highest-performing configurations.}}{39}{figure.2.19}%
