\contentsline {figure}{\numberline {A.3}{\ignorespaces Fine-tuned --- best: EfficientNetB1 FT, $K=3$, freq\_strength, E3\_YES (88.1\%, 37/42).}}{76}{figure.1.A.3}%
\contentsline {figure}{\numberline {A.4}{\ignorespaces Fine-tuned --- worst: ResNet50 FT, $K=3$, per\_species\_avg, E4\_YES (7.1\%, 3/42).}}{77}{figure.1.A.4}%
\contentsline {figure}{\numberline {A.5}{\ignorespaces Pretrained --- best: MobileNetV2 PT, $K=5$, freq\_strength, E4\_DG18 (81.0\%, 34/42).}}{78}{figure.1.A.5}%
